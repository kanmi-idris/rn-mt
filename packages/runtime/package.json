{
  "name": "@rn-mt/runtime",
  "version": "0.1.0",
  "description": "Runtime integration helpers for converted rn-mt host apps.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@rn-mt/shared": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
