{
  "name": "@_molaidrislabs/core",
  "private": true,
  "version": "0.1.0",
  "description": "Core schema, analysis, sync, audit, and reconstruction engine for rn-mt.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kanmi-idris/rn-mt.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/kanmi-idris/rn-mt/issues"
  },
  "homepage": "https://github.com/kanmi-idris/rn-mt/tree/main/packages/core",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
