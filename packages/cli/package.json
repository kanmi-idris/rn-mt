{
  "name": "@rn-mt/cli",
  "version": "0.1.0",
  "description": "Bootstrap and project-local command runner for rn-mt.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rn-mt": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@rn-mt/core": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts --help",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
