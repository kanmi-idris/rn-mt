{
  "name": "@molaidrislabs/cli",
  "version": "0.1.0",
  "description": "Bootstrap and project-local command runner for rn-mt.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rn-mt": "dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kanmi-idris/rn-mt.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/kanmi-idris/rn-mt/issues"
  },
  "homepage": "https://github.com/kanmi-idris/rn-mt/tree/main/packages/cli",
  "dependencies": {
    "@molaidrislabs/core": "workspace:*",
    "@molaidrislabs/shared": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts --help",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
