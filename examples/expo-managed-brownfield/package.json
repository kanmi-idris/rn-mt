{
  "name": "@rn-mt-example/expo-managed-brownfield",
  "private": true,
  "description": "Brownfield Expo managed example with aliases, layered config, and existing scripts.",
  "license": "MIT",
  "version": "1.4.0",
  "main": "index.ts",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:staging": "EXPO_PUBLIC_API_BASE_URL=https://staging.example.dev expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "verify:ios": "expo export --platform ios --output-dir .expo-export"
  },
  "dependencies": {
    "expo": "~55.0.2",
    "expo-constants": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.3",
    "react-native": "0.85.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  }
}
