{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:file((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/]+\\.\\w+)/",
      "destination": "/:file",
      "internal": true,
      "missing": [
        {
          "type": "header",
          "key": "x-nextjs-data"
        }
      ],
      "statusCode": 308,
      "regex": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/]+\\.\\w+))/$"
    },
    {
      "source": "/:notfile((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/\\.]+)",
      "destination": "/:notfile/",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/\\.]+))$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/agent-skill",
      "regex": "^/agent\\-skill(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/agent\\-skill(?:/)?$"
    },
    {
      "page": "/architecture",
      "regex": "^/architecture(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/architecture(?:/)?$"
    },
    {
      "page": "/command-reference",
      "regex": "^/command\\-reference(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/command\\-reference(?:/)?$"
    },
    {
      "page": "/contributing",
      "regex": "^/contributing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contributing(?:/)?$"
    },
    {
      "page": "/convert-an-app",
      "regex": "^/convert\\-an\\-app(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/convert\\-an\\-app(?:/)?$"
    },
    {
      "page": "/examples",
      "regex": "^/examples(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/examples(?:/)?$"
    },
    {
      "page": "/get-started",
      "regex": "^/get\\-started(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/get\\-started(?:/)?$"
    },
    {
      "page": "/introduction",
      "regex": "^/introduction(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/introduction(?:/)?$"
    },
    {
      "page": "/targets-and-sync",
      "regex": "^/targets\\-and\\-sync(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/targets\\-and\\-sync(?:/)?$"
    },
    {
      "page": "/troubleshooting",
      "regex": "^/troubleshooting(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/troubleshooting(?:/)?$"
    },
    {
      "page": "/workflow-hooks",
      "regex": "^/workflow\\-hooks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/workflow\\-hooks(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}