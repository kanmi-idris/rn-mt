{
  "name": "rn-mt",
  "private": true,
  "version": "0.1.0",
  "description": "Manifest-driven multitenancy conversion platform for React Native and Expo apps.",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rimraf coverage dist .turbo",
    "dev:cli": "pnpm --filter @_molaidrislabs/cli dev",
    "docs:build": "pnpm --filter @_molaidrislabs/docs build",
    "docs:dev": "pnpm --filter @_molaidrislabs/docs dev",
    "docs:start": "pnpm --filter @_molaidrislabs/docs start",
    "examples:verify": "node ./scripts/verify-examples.mjs",
    "lint": "pnpm -r lint",
    "prepublishOnly": "node -e \"console.error('Do not publish the private workspace root. Use npm run release:publish:npm or pnpm release:publish.'); process.exit(1)\"",
    "release:dry-run": "pnpm build && pnpm --filter @_molaidrislabs/rn-mt publish --dry-run --report-summary --access public --no-git-checks",
    "release:publish": "pnpm build && pnpm --filter @_molaidrislabs/rn-mt publish --report-summary --access public --no-git-checks",
    "release:dry-run:npm": "pnpm build && npm publish ./packages/rn-mt --dry-run --access public",
    "release:publish:npm": "pnpm build && npm publish ./packages/rn-mt --access public",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
